# OSV Platform — Local Development Environment
# Copy to .env and fill in your values
#
# =============================================================
# USAGE:
#   cp deploy/dev/.env.example deploy/dev/.env
#   docker-compose -f deploy/dev/docker-compose.yml up -d
# =============================================================

# ── PostgreSQL ──────────────────────────────────────────────────────────────
# pgvector/pgvector:pg16 image — includes pgvector extension
POSTGRES_USER=osv
POSTGRES_PASSWORD=osv_dev_secret   # thay đổi trước production
POSTGRES_DB=osvdb                  # consistent with POSTGRES_DSN in .env.bootstrap

# ── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_DB=cvedb                     # ranking-service collection: cvedb.ranking

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=                    # để trống = no auth (dev)

# ── NATS ─────────────────────────────────────────────────────────────────────
NATS_ENABLED=true

# ── Search ───────────────────────────────────────────────────────────────────
OPENSEARCH_INDEX=vulnerabilities
SEARCH_BACKEND=auto                # auto = OpenSearch → fallback PostgreSQL GIN

# ── Storage backend ──────────────────────────────────────────────────────────
# Code: services/data-service/internal/config/storage_config.go
ALIAS_GROUP_BACKEND=postgres       # postgres (local dev) | firestore (GCP)

# ── Identity & JWT ───────────────────────────────────────────────────────────
# Spec: 01-architecture.md §3.10 — RS256 JWT + Argon2id password hashing
# Generate: openssl rand -hex 32
JWT_SECRET=dev-secret-change-in-production-min-32-chars
JWT_ISSUER=https://auth.openvulnscan.io
JWT_AUDIENCE=openvulnscan

# ── Admin account seed ────────────────────────────────────────────────────────
INIT_ADMIN_EMAIL=admin@openvulnscan.io
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=Admin@123!ChangeMe   # thay đổi sau khi setup

# ── AI Service ───────────────────────────────────────────────────────────────
# Spec: 01-architecture.md §14.5 — LLM Provider Chain
AI_BACKEND=ollama                  # ollama | openai | vertex
AI_MODEL=llama3
AI_BASE_URL=http://host.docker.internal:11434   # Ollama trên host machine
OPENAI_API_KEY=
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1

# ── Notifications (optional) ─────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Dev flags ────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
FORCE_INSECURE=true                # bỏ qua JWT_SECRET security check trong dev
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173
