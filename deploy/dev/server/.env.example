# =============================================================
# OSV Platform — Server Environment (172.20.2.48)
# Copy this to .env and fill in secrets before first deploy
#
# Usage:
#   scp deploy/dev/server/.env.example ubuntu@172.20.2.48:/opt/osv/.env.example
#   ssh ubuntu@172.20.2.48 "cp /opt/osv/.env.example /opt/osv/.env && nano /opt/osv/.env"
# =============================================================

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_strong_password_min_16_chars
POSTGRES_DB=osvdb

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_DB=cvedb

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password

# ── NATS ─────────────────────────────────────────────────────────────────────
NATS_ENABLED=true

# ── JWT & Identity ────────────────────────────────────────────────────────────
# RSA private key stored in ./secrets/jwt_private.pem (mounted at /run/secrets/)
# Generate: openssl genrsa -out secrets/jwt_private.pem 4096
JWT_SECRET=CHANGE_ME_min_32_chars_random_secret
JWT_EXPIRY=24h
JWT_ISSUER=https://auth.openvulnscan.io
JWT_AUDIENCE=openvulnscan

# ── Admin account (seeded on first run) ──────────────────────────────────────
INIT_ADMIN_EMAIL=admin@openvulnscan.io
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# ── Search ────────────────────────────────────────────────────────────────────
SEARCH_BACKEND=auto
OPENSEARCH_INDEX=vulnerabilities

# ── Storage backend ───────────────────────────────────────────────────────────
ALIAS_GROUP_BACKEND=postgres

# ── AI (chọn một backend) ─────────────────────────────────────────────────────
AI_BACKEND=openai            # openai | ollama | vertex
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-...
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1

# ── Notifications ─────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Misc ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
ALLOWED_ORIGINS=https://c12.openledger.vn
