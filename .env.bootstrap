# =============================================================================
# OSV Platform — .env.bootstrap
# Generated from: specs/crs/v0/init-account/solutions/SOL-INIT-001
# Architecture ref: specs/01-architecture.md §4 (Infrastructure Layer)
# =============================================================================
# Usage:
#   cp .env.bootstrap .env
#   # Thay các giá trị có chú thích [REQUIRED]
#   ./scripts/bootstrap.sh
# =============================================================================

# =============================================================================
# POSTGRESQL 16 + pgvector
# Spec: 01-architecture.md §4.1 — Schema-per-service trong cùng một cluster
# Schemas: auth (identity), vuln (data), notif (notification)
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=osv
POSTGRES_PASSWORD=osv_dev_secret_CHANGE_ME   # [REQUIRED] thay trong production
POSTGRES_DB=osvdb

# DSN tổng hợp — dùng bởi scripts/bootstrap.sh
POSTGRES_DSN=postgres://osv:osv_dev_secret_CHANGE_ME@localhost:5432/osvdb?sslmode=disable

# Per-service DSNs
IDENTITY_DATABASE_URL=postgres://osv:osv_dev_secret_CHANGE_ME@localhost:5432/osvdb?sslmode=disable
DATA_DATABASE_URL=postgres://osv:osv_dev_secret_CHANGE_ME@localhost:5432/osvdb?sslmode=disable
NOTIFICATION_DATABASE_URL=postgres://osv:osv_dev_secret_CHANGE_ME@localhost:5432/osvdb?sslmode=disable

# =============================================================================
# REDIS 7
# Spec: 01-architecture.md §4.3 — Rate-limiting, caching, JWT token store
# Key patterns: ratelimit:{ip}, osv:embed:{cve_id}, osv:jwt:revoked:{jti}
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# URL format cho identity-service (redis.ParseURL)
REDIS_URL=redis://localhost:6379/0
# Addr format cho search-service (redis.Options{Addr})
REDIS_ADDR=localhost:6379

# =============================================================================
# MONGODB — dùng bởi ranking-service
# Spec: 01-architecture.md §3.11 (ranking-service: CPE popularity ranking)
# =============================================================================
MONGO_URI=mongodb://localhost:27017
MONGO_DB=cvedb

# =============================================================================
# NATS JETSTREAM
# Spec: 01-architecture.md §4.4 — Async event-driven communication
# Streams: INGESTION, FINDINGS, SLA, KEV, JIRA, AUDIT
# false = notification-service chạy được dù NATS chưa available (graceful warn)
# =============================================================================
NATS_URL=nats://localhost:4222
NATS_ENABLED=false

# =============================================================================
# OPENSEARCH 2
# Spec: 01-architecture.md §4.2 — BM25 full-text + aggregations
# Index mapping: cve_id(keyword), description(text/english), severity(keyword),
#                cvss_v3_score(float), epss_score(float), is_kev(boolean)
# auto = try OpenSearch → fallback PostgreSQL GIN index
# =============================================================================
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=vulnerabilities
SEARCH_BACKEND=auto

# =============================================================================
# IDENTITY-SERVICE
# Spec: 01-architecture.md §3.10 — Auth Chain (Local + LDAP) + API Keys
# Code: services/identity-service/internal/infrastructure/jwt/token.go
#       RS256 (RSA-4096), PublicKeyJWKS() cho JWKS endpoint
# Code: services/identity-service/internal/infrastructure/crypto/argon2id.go
#       Argon2id: memory=64MB, iterations=3, parallelism=2 (OWASP minimum)
# Ports: HTTP=9101, gRPC=9001
# =============================================================================
IDENTITY_HTTP_PORT=9101
IDENTITY_GRPC_PORT=9001

# RSA-4096 private key — tạo bằng: openssl genrsa -out secrets/jwt_private.pem 4096
JWT_PRIVATE_KEY_PATH=secrets/jwt_private.pem
JWT_ISSUER=https://auth.openvulnscan.io
JWT_AUDIENCE=openvulnscan

# Admin account seed — tạo lần đầu bởi bootstrap script
# Code: scripts/bootstrap.sh → identity-service/scripts/init.sh
INIT_ADMIN_EMAIL=admin@openvulnscan.io
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=Admin@123!ChangeMe   # [REQUIRED] thay bằng password mạnh

# OAuth2 providers (tùy chọn)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:9101/api/v1/auth/oauth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:9101/api/v1/auth/oauth/github/callback

# LDAP Auth Chain (tùy chọn)
# Spec: 01-architecture.md §3.10 Auth Chain — "local" → "ldap" configurable order
LDAP_HOST=
LDAP_PORT=389
LDAP_BASE_DN=dc=example,dc=com
LDAP_USER_ATTR=uid
LDAP_USE_TLS=false
LDAP_SKIP_VERIFY=false

# =============================================================================
# DATA-SERVICE
# Spec: 01-architecture.md §3.2 — CVE Data Platform (15+ fetchers)
# Ports: HTTP=8082, gRPC=50053, Metrics=9092
# =============================================================================
DATA_HTTP_PORT=8082
DATA_GRPC_PORT=50053

# Storage backend cho alias groups (code: internal/config/storage_config.go)
# "postgres" = dùng migration 005_create_alias_groups.up.sql
# "firestore" = dùng GCP Firestore (legacy mode, yêu cầu GCP_PROJECT_ID)
ALIAS_GROUP_BACKEND=postgres

# GCP (chỉ khi ALIAS_GROUP_BACKEND=firestore)
GCP_PROJECT_ID=osv-local
FIRESTORE_EMULATOR_HOST=localhost:8200
GCS_BUCKET=osv-vulnerabilities-local

# OpenTelemetry (Spec: 01-architecture.md §8)
OTLP_ENDPOINT=http://localhost:4318
OTEL_SAMPLING_RATE=1.0

# =============================================================================
# SEARCH-SERVICE
# Spec: 01-architecture.md §3.3 — Dual Backend (OpenSearch primary, PG fallback)
# Ports: HTTP=8083, gRPC=50056, Metrics=9091
# =============================================================================
SEARCH_HTTP_PORT=8083
SEARCH_GRPC_PORT=50056

# =============================================================================
# RANKING-SERVICE
# Spec: 01-architecture.md §2.2 — CPE popularity ranking
# Code: services/ranking-service/cmd/server/main.go — dùng RANKING_PORT → PORT
# Port: HTTP=8088
# =============================================================================
RANKING_PORT=8088

# =============================================================================
# NOTIFICATION-SERVICE
# Spec: 01-architecture.md §3.7 — 5-channel dispatch + HMAC webhook signing
# Channels: Email, Slack, Teams, In-app, Webhook
# Ports: HTTP=8086, gRPC=50063, Metrics=9094
# =============================================================================
NOTIFICATION_HTTP_PORT=8086
NOTIFICATION_GRPC_PORT=50063

# SMTP (chỉ khi dùng email channel)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# =============================================================================
# AI-SERVICE
# Spec: 01-architecture.md §14.5 — LLM Provider Chain (Ollama → OpenAI → Azure)
# Code: services/ai-service/internal/infra/ai/factory.go — FromEnv(), Validate()
# Port: gRPC=50052
# =============================================================================
AI_GRPC_PORT=50052
AI_BACKEND=ollama              # ollama | vertex | openai
AI_MODEL=llama3
AI_BASE_URL=http://localhost:11434

# Vertex AI (khi AI_BACKEND=vertex) — bắt buộc VERTEX_PROJECT_ID
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1

# OpenAI (khi AI_BACKEND=openai) — bắt buộc OPENAI_API_KEY
OPENAI_API_KEY=

# =============================================================================
# GATEWAY-SERVICE (services/gateway-service)
# Spec: 01-architecture.md §3.1 — Reverse Proxy: auth + rate-limit + routing
# Ports: HTTP=8080, gRPC=9090
# =============================================================================
GATEWAY_HTTP_PORT=8080
GATEWAY_GRPC_PORT=9090

# Upstream HTTP addresses (theo spec §2.2 Port Map)
DATA_SERVICE_HTTP=http://localhost:8082
SEARCH_SERVICE_HTTP=http://localhost:8083
NOTIFICATION_SERVICE_HTTP=http://localhost:8086

# =============================================================================
# APPS/OSV (Unified Gateway Orchestrator)
# Spec: 01-architecture.md §2.1 — "UNIFIED GATEWAY apps/osv :8080"
# Code: apps/osv/internal/config/config.go — Mode, ServiceAddrs, EmbeddedInfra
# Port: HTTP=8080
# =============================================================================
OSV_MODE=microservices         # standalone | microservices
HTTP_PORT=8080

# gRPC upstream addresses (theo spec Port Map)
DATA_SERVICE_ADDR=localhost:50053
AI_SERVICE_ADDR=localhost:50052
FINDING_SERVICE_ADDR=localhost:50060
IDENTITY_SERVICE_ADDR=localhost:9001

# HTTP upstream addresses
NOTIFICATION_HTTP=http://localhost:8086
GATEWAY_HTTP=http://localhost:8080
RANKING_SERVICE_HTTP=http://localhost:8088
IDENTITY_SERVICE_HTTP=http://localhost:9101

# JWT validation — apps/osv validate JWT từ identity-service qua JWKS
# Code: apps/osv/internal/gateway/auth/middleware.go
JWKS_URL=http://localhost:9101/.well-known/jwks.json
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_32   # [REQUIRED] openssl rand -hex 32

# CORS
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173

# EmbeddedInfra (dùng khi OSV_MODE=microservices)
# Note: POSTGRES_DSN và REDIS_ADDR đã định nghĩa ở trên

# =============================================================================
# OBSERVABILITY — Grafana (Spec: 01-architecture.md §8)
# =============================================================================
GF_SECURITY_ADMIN_PASSWORD=admin_grafana_CHANGE_ME   # [REQUIRED]
GF_AUTH_ANONYMOUS_ENABLED=true

# =============================================================================
# BOOTSTRAP CONTROL FLAGS
# =============================================================================
FORCE_INSECURE=false           # true = bỏ qua security checks (local dev only)
SKIP_INFRA_CHECK=false         # true = bỏ qua kiểm tra infra connectivity
BOOTSTRAP_TIMEOUT=30           # Timeout chờ service health check (giây)
