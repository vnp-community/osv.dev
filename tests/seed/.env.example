# ============================================================
# OSV Seed Scripts — Configuration
# Copy to .env and fill in real values
# ============================================================

# API Gateway URL (no trailing slash)
GATEWAY_URL=http://localhost:8080

# Admin credentials (used to login and get JWT)
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=AdminPass123!

# Alternatively, provide a pre-generated admin API key
# If set, skips login and uses this key directly
ADMIN_API_KEY=

# Data directories
SEED_DATA_DIR=./data
SEED_OUTPUT_DIR=./data/output

# Script behavior
# Number of retry attempts on 5xx errors
RETRY_ATTEMPTS=3
# Delay between retries (seconds)
RETRY_DELAY=2
# Request timeout (seconds)
REQUEST_TIMEOUT=30
# Verbose logging: true/false
VERBOSE=false

# Optional: push data to a specific base URL for services (direct, bypassing gateway)
# Leave empty to use gateway URL
IDENTITY_SERVICE_URL=
FINDING_SERVICE_URL=
SCAN_SERVICE_URL=
ASSET_SERVICE_URL=
SLA_SERVICE_URL=
NOTIFICATION_SERVICE_URL=
JIRA_SERVICE_URL=
RANKING_SERVICE_URL=
AI_SERVICE_URL=
DATA_SERVICE_URL=
