# =============================================================================
# OSV Platform API — Test Client Environment Variables
# =============================================================================
# Copy to .env and fill in the values:
#   cp .env.example .env
# =============================================================================

# Base URL của API server
# v1 endpoints: http://localhost:8080/api/v1
# v2 endpoints: http://localhost:8080/api/v2
API_BASE_URL_V1=http://localhost:8080/api/v1
API_BASE_URL_V2=http://localhost:8080/api/v2

# Credentials để test auth
TEST_EMAIL=admin@osv.local
TEST_PASSWORD=changeme

# (Optional) JWT token nếu đã có sẵn — bỏ trống để auto-login
ACCESS_TOKEN=

# Timeout cho mỗi HTTP request (giây)
REQUEST_TIMEOUT=30

# Bật verbose logging (true/false)
VERBOSE=true

# Sample IDs dùng trong test (tuỳ dữ liệu trong DB)
SAMPLE_CVE_ID=CVE-2021-44228
SAMPLE_SCAN_ID=
SAMPLE_FINDING_ID=
SAMPLE_PRODUCT_ID=
SAMPLE_ASSET_ID=
SAMPLE_CWE_ID=CWE-89
SAMPLE_CAPEC_ID=CAPEC-66
SAMPLE_VENDOR=apache
SAMPLE_PRODUCT_NAME=log4j

# =============================================================================
# New Sample IDs — CR-008 to CR-014 (openapi.yaml updates)
# =============================================================================

# Webhook tests (test_webhook_deliveries.py)
# SAMPLE_WEBHOOK_ID: ID của một webhook trong DB
# SAMPLE_WEBHOOK_DELIVERY_ID: ID của một FAILED delivery (để test retry)
# SAMPLE_SUCCESS_DELIVERY_ID: ID của một SUCCESS delivery (để test 422 no-retry)
SAMPLE_WEBHOOK_ID=
SAMPLE_WEBHOOK_DELIVERY_ID=
SAMPLE_SUCCESS_DELIVERY_ID=

# AI Triage Queue tests (test_ai_triage_queue.py)
# SAMPLE_TRIAGE_FINDING_ID: ID của finding CHƯA được review (status=pending)
# SAMPLE_REVIEWED_FINDING_ID: ID của finding ĐÃ được review (để test 409 Conflict)
SAMPLE_TRIAGE_FINDING_ID=
SAMPLE_REVIEWED_FINDING_ID=

# =============================================================================
# Additional IDs — test_missing_endpoints.py (full api_endpoints.md coverage)
# =============================================================================

# Admin user detail tests
# SAMPLE_USER_ID: ID của một user trong DB (để test GET /admin/users/{id})
SAMPLE_USER_ID=

# Report tests
# SAMPLE_REPORT_ID: ID của một report đã tồn tại (để test GET/DELETE /reports/{id})
SAMPLE_REPORT_ID=

# Risk acceptance tests
# SAMPLE_RISK_ACCEPTANCE_ID: ID của một risk acceptance (để test DELETE /risk-acceptances/{id})
SAMPLE_RISK_ACCEPTANCE_ID=

# Engagement tests
# SAMPLE_ENGAGEMENT_ID: ID của một engagement (để test GET /engagements/{id}/tests)
SAMPLE_ENGAGEMENT_ID=
