# CVE Binary Tool Additional Environment Variables
# Copy this file to .env and fill in the values

# NVD API Key (required for full-speed NVD sync)
NVD_API_KEY=

# NVD sync mode: json-mirror | api2 | offline
NVD_MODE=json-mirror

# GitHub token (for GitHub Advisory Database source)
GAD_GITHUB_TOKEN=

# gRPC service ports
SCANNER_GRPC_PORT=50051
CVEDB_GRPC_PORT=50052
DATASYNC_GRPC_PORT=50053
REPORTER_GRPC_PORT=50054
SBOMVEX_GRPC_PORT=50055

# API Gateway
GATEWAY_HTTP_PORT=8080
GATEWAY_GRPC_PORT=9090
JWT_SECRET=change-me-in-production

# Service addresses (for api-gateway)
SCANNER_ADDR=scanner:50051
CVEDB_ADDR=cve-service:50052
DATASYNC_ADDR=cve-sync-service:50053
REPORTER_ADDR=report-service:50054
SBOMVEX_ADDR=sbomvex:50055

# Rate limiting
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=30

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Log level: debug | info | warn | error
LOG_LEVEL=info
