FROM golang:1.22-alpine AS builder
WORKDIR /app
COPY go.mod ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /ai-enrichment ./cmd/server

FROM gcr.io/distroless/static-debian12
COPY --from=builder /ai-enrichment /ai-enrichment
EXPOSE 50051 8080 9090
ENTRYPOINT ["/ai-enrichment"]
