<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CVE Binary Tool Report — {{.Target}}</title>
    <script src="https://cdn.plot.ly/plotly-2.27.0.min.js" charset="utf-8"></script>
    <style>{{.CSS}}</style>
</head>
<body class="theme-{{.Theme}}">
<header>
    <div class="header-content">
        <h1>🔍 CVE Scan Report</h1>
        <div class="meta">
            <span><strong>Target:</strong> {{.Target}}</span>
            <span><strong>Generated:</strong> {{.Timestamp}}</span>
            <span class="badge-total">{{.TotalCVEs}} CVE(s) Found</span>
        </div>
    </div>
</header>

<section class="summary-section">
    <div id="severity-chart" style="width:500px;height:350px;"></div>
    <div class="severity-counts">
        {{range $sev, $count := .SeverityCounts}}
        <div class="sev-count badge-{{lower $sev}}">{{$sev}}: {{$count}}</div>
        {{end}}
    </div>
</section>

{{range .Products}}
<section class="product-section">
    <h2>{{.Vendor}} / {{.Product}} <span class="version">{{.Version}}</span>
        {{if .PURL}}<code class="purl">{{.PURL}}</code>{{end}}
    </h2>
    {{if .CVEs}}
    <table class="cve-table">
        <thead>
            <tr>
                <th>CVE Number</th>
                <th>Severity</th>
                <th>Score</th>
                <th>CVSS Vector</th>
                <th>Exploit</th>
                <th>Source</th>
            </tr>
        </thead>
        <tbody>
        {{range .CVEs}}
        <tr class="row-{{lower .Severity}}">
            <td><a href="https://nvd.nist.gov/vuln/detail/{{.CVENumber}}" target="_blank" rel="noopener">{{.CVENumber}}</a></td>
            <td><span class="badge-{{lower .Severity}}">{{.Severity}}</span></td>
            <td class="score">{{printf "%.1f" .Score}}</td>
            <td class="vector">{{.CVSSVector}}</td>
            <td>{{if .IsExploit}}<span class="exploit-badge">⚠ Yes</span>{{else}}—{{end}}</td>
            <td>{{.DataSource}}</td>
        </tr>
        {{end}}
        </tbody>
    </table>
    {{else}}
    <p class="no-cve">No CVEs found.</p>
    {{end}}
</section>
{{end}}

<footer>
    <p>Generated by <strong>CVE Binary Tool</strong> | <a href="https://github.com/intel/cve-bin-tool">https://github.com/intel/cve-bin-tool</a></p>
</footer>

<script>
{{.ChartJS}}
</script>
</body>
</html>
