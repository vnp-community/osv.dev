# =============================================================================
# OSV.dev — Local Development Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# All services are configured via environment variables.
# This file documents every variable used across the docker-compose stack.
# =============================================================================

# ---------------------------------------------------------------------------
# GCP / Emulator
# ---------------------------------------------------------------------------
# GCP project ID (use "osv-local" for local dev with emulators)
GCP_PROJECT_ID=osv-local

# Firestore emulator host (set when using the local emulator)
FIRESTORE_EMULATOR_HOST=firestore-emulator:8200

# GCS bucket for vulnerability data (local dev only)
GCS_BUCKET=osv-vulnerabilities-local

# ---------------------------------------------------------------------------
# Message Bus — NATS (JetStream)
# ---------------------------------------------------------------------------
NATS_URL=nats://nats:4222

# ---------------------------------------------------------------------------
# Cache — Redis
# ---------------------------------------------------------------------------
REDIS_ADDR=redis:6379

# ---------------------------------------------------------------------------
# Observability — OpenTelemetry
# ---------------------------------------------------------------------------
OTLP_ENDPOINT=http://otel-collector:4318
# Sampling rate: 1.0 = 100% (use lower in production)
OTEL_SAMPLING_RATE=1.0

# ---------------------------------------------------------------------------
# Search — OpenSearch
# ---------------------------------------------------------------------------
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INDEX=vulnerabilities

# ---------------------------------------------------------------------------
# Authentication — JWT (API Gateway)
# ---------------------------------------------------------------------------
# JWKS endpoint for public key retrieval
JWKS_URL=http://localhost:8080/.well-known/jwks.json
# Expected audience claim in JWT
JWT_AUDIENCE=osv-api
# Expected issuer claim in JWT
JWT_ISSUER=https://accounts.google.com

# ---------------------------------------------------------------------------
# AI Enrichment Service
# ---------------------------------------------------------------------------
# Local Ollama endpoint (optional, for local LLM)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=llama3.2

# Primary AI provider: "vertex" | "openai" | "ollama"
AI_PROVIDER_PRIMARY=vertex

# Google Vertex AI (used when AI_PROVIDER_PRIMARY=vertex)
VERTEX_PROJECT_ID=osv-local
VERTEX_REGION=us-central1

# OpenAI (used when AI_PROVIDER_PRIMARY=openai)
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Web BFF — Cross-Origin
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173

# ---------------------------------------------------------------------------
# Inter-Service Addresses (docker-compose internal DNS)
# ---------------------------------------------------------------------------
QUERY_SERVICE_ADDR=vulnerability-query:50051
SEARCH_SERVICE_ADDR=search:50052
AI_ENRICHMENT_ADDR=ai-enrichment:50054
ALIAS_SERVICE_ADDR=alias-relations:50057

# ---------------------------------------------------------------------------
# Impact Analysis / Version Index — Git clone cache
# ---------------------------------------------------------------------------
CLONE_DIR=/tmp/repos

# ---------------------------------------------------------------------------
# Grafana (local monitoring dashboard)
# ---------------------------------------------------------------------------
# Change before exposing to any network
GF_SECURITY_ADMIN_PASSWORD=admin
GF_AUTH_ANONYMOUS_ENABLED=true
