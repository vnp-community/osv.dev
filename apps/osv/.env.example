# ── OSV Gateway Configuration ─────────────────────────────────────────────────
# Copy to .env and customize for your environment.
# All variables have sensible defaults (see internal/config/config.go).

# ── Gateway ───────────────────────────────────────────────────────────────────
# Server mode: "standalone" (GCP pipeline) | "microservices" (full embedded orchestration)
OSV_MODE=microservices

# HTTP gateway port
HTTP_PORT=8080

# ── Existing gRPC service addresses ──────────────────────────────────────────
DATA_SERVICE_ADDR=localhost:50053
AI_SERVICE_ADDR=localhost:50052
FINDING_SERVICE_ADDR=localhost:50060
IDENTITY_SERVICE_ADDR=localhost:50051

# ── Existing HTTP service addresses ──────────────────────────────────────────
NOTIFICATION_HTTP=http://localhost:8084
GATEWAY_HTTP=http://localhost:8080

# ── NATS ─────────────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── NEW — CVE Search CRs (CR-001 through CR-009) ─────────────────────────────

# CR-001 (CPE search), CR-003 (taxonomy), CR-005 (dbinfo),
# CR-006 (feed), CR-008 (query), CR-009 (export):
# data-service HTTP REST base URL
DATA_SERVICE_HTTP=http://localhost:8082

# CR-002 (browse vendors/products):
# search-service HTTP base URL
SEARCH_SERVICE_HTTP=http://localhost:8083

# CR-004 (CPE ranking lookup and management):
# ranking-service HTTP base URL (new service, port 8088)
RANKING_SERVICE_HTTP=http://localhost:8088

# CR-007 (LDAP auth, identity admin endpoints):
# identity-service HTTP base URL
IDENTITY_SERVICE_HTTP=http://localhost:9101

# ── EmbeddedInfra (required khi OSV_MODE=microservices) ─────────────────────
# PostgreSQL DSN — dùng bởi apps/osv cho embedded infra connection
POSTGRES_DSN=postgres://osv:osv_dev_secret_CHANGE_ME@localhost:5432/osvdb?sslmode=disable

# Redis addr — dùng bởi rate limiter (ratelimit:{ip})
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# JWT signing secret cho gateway JWT validation
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_32

# JWKS endpoint của identity-service (để validate RS256 JWT tại gateway)
# Code: services/gateway-service/internal/auth/osv_middleware.go — AuthVerify()
JWKS_URL=http://localhost:9101/.well-known/jwks.json
JWT_AUDIENCE=openvulnscan
JWT_ISSUER=https://auth.openvulnscan.io
