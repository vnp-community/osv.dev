# .env.example — OpenVulnScan Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env && vim .env

# ── Application ───────────────────────────────────────────────────────────────
VERSION=1.0.0
HTTP_PORT=8080

# ── Admin Account ─────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=change-me-strong-password-min-12-chars

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_PASSWORD=change-me-strong-db-password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-password

# ── MinIO Object Storage ──────────────────────────────────────────────────────
MINIO_USER=minioadmin
MINIO_PASSWORD=change-me-minio-password

# ── SIEM / Syslog (optional) ──────────────────────────────────────────────────
SIEM_ENABLED=false
SIEM_HOST=
SIEM_PORT=514
SIEM_PROTOCOL=udp

# ── Slack Notifications (optional) ───────────────────────────────────────────
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ── Build Info ────────────────────────────────────────────────────────────────
BUILD_TIME=
