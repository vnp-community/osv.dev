# GlobalCVE Monolithic App — Environment Variables

# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/globalcve?sslmode=disable

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── OpenSearch ────────────────────────────────────────────────────────────
OPENSEARCH_URL=http://localhost:9200

# ─── NATS JetStream ────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ─── External APIs ─────────────────────────────────────────────────────────
# NVD API Key (optional — higher rate limits: 50 req/30s vs 5 req/30s)
# Register at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# ─── App Config ────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ─── Internal Service Ports (optional overrides) ───────────────────────────
# GATEWAY_PORT=8080
# CVESEARCH_PORT=8081
# CVESYNC_PORT=8082
# KEVSERVICE_PORT=8083
# NOTIFICATION_PORT=8084
# METRICS_PORT=9090
